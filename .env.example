ASPNETCORE_ENVIRONMENT=Development
DATABASE_PATH=data/ainews.db

PUBLISH_MODE=Manual
OPS_AUTH_MODE=EmailCode
OPS_SESSION_COOKIE_NAME=AiNewsCurator.Ops.Auth
OPS_LOGIN_CODE_TTL_MINUTES=10
OPS_LOGIN_MAX_VERIFY_ATTEMPTS=5
OPS_BOOTSTRAP_EMAIL=ops@example.com
OPS_BOOTSTRAP_NAME=Ops User
ENABLE_SCHEDULER=false
RUN_HOUR_LOCAL=08
RUN_MINUTE_LOCAL=00
TIMEZONE=America/Sao_Paulo

INTERNAL_API_KEY=changeme
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_NAME=AI News Curator
SMTP_SENDER_EMAIL=youraccount@gmail.com
SMTP_USERNAME=youraccount@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_USE_STARTTLS=true

LINKEDIN_CLIENT_ID=77hj3yc1ucbwpk
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5138/internal/auth/linkedin/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_URN=

AI_PROVIDER=Heuristic
AI_API_KEY=
AI_MODEL_NAME=local-heuristic
AI_BASE_URL=

MAX_NEWS_PER_RUN=50
MAX_CANDIDATES_FOR_AI=10
RELEVANCE_THRESHOLD=0.75
CONFIDENCE_THRESHOLD=0.80
DUPLICATE_LOOKBACK_DAYS=14
POST_LOOKBACK_DAYS=15
NEWS_WINDOW_HOURS=48
LINKEDIN_TONE=Editorial
ATTRIBUTION_FOOTER_LINE=Curated by AI News Curator.
