ASPNETCORE_ENVIRONMENT=Development
DATABASE_PATH=data/ainews.db

PUBLISH_MODE=Manual
RUN_HOUR_LOCAL=08
RUN_MINUTE_LOCAL=00
TIMEZONE=America/Sao_Paulo

INTERNAL_API_KEY=changeme

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_ACCESS_TOKEN=
