@model AiNewsCurator.Api.Models.Operations.OperationsDashboardViewModel
@{
    ViewData["Title"] = "Operations";
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<style>
    .ops-loading-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.35);
        backdrop-filter: blur(2px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 24px;
    }

    .ops-loading-overlay.active {
        display: flex;
    }

    .ops-loading-card {
        background: #fffaf3;
        border: 1px solid rgba(184, 115, 51, 0.25);
        border-radius: 18px;
        padding: 20px 24px;
        min-width: 280px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
        text-align: center;
    }

    .ops-loading-spinner {
        width: 26px;
        height: 26px;
        border-radius: 999px;
        border: 3px solid rgba(184, 115, 51, 0.18);
        border-top-color: #b87333;
        margin: 0 auto 12px;
        animation: ops-spin 0.8s linear infinite;
    }

    button.is-loading {
        opacity: 0.8;
        cursor: wait;
    }

    @@keyframes ops-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div id="ops-loading-overlay" class="ops-loading-overlay" aria-live="polite" aria-hidden="true">
    <div class="ops-loading-card">
        <div class="ops-loading-spinner" aria-hidden="true"></div>
        <strong id="ops-loading-title">Processing request...</strong>
        <div id="ops-loading-description" class="muted" style="margin-top: 8px;">Please wait until the operation finishes.</div>
    </div>
</div>

<div class="topbar">
    <div class="brand">
        <div class="brand-lockup">
            <img src="~/favicon.png" alt="AI News Curator logo" class="brand-logo" />
            <div>
                <h1>AI News Curator</h1>
                <p>Editorial workspace for daily operations, draft review, and source management.</p>
            </div>
        </div>
    </div>

    <div class="actions" style="align-items: center;">
        <span class="badge neutral">Signed in as @(Context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? Context.User.Identity?.Name ?? "ops user")</span>
        <form method="post" action="/ops/auth/logout">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <button type="submit" class="secondary">Sign out</button>
        </form>
    </div>
</div>

<script>
    (() => {
        const overlay = document.getElementById('ops-loading-overlay');
        const title = document.getElementById('ops-loading-title');
        const description = document.getElementById('ops-loading-description');

        if (!overlay || !title || !description) {
            return;
        }

        const postForms = Array.from(document.querySelectorAll('form[method="post"]'));
        for (const form of postForms) {
            form.addEventListener('submit', event => {
                if (form.dataset.loadingActive === 'true') {
                    event.preventDefault();
                    return;
                }

                const submitter = event.submitter;
                const buttonText = submitter?.dataset.loadingText
                    || submitter?.textContent?.trim()
                    || 'Processing request...';

                form.dataset.loadingActive = 'true';
                overlay.classList.add('active');
                overlay.setAttribute('aria-hidden', 'false');
                title.textContent = buttonText;
                description.textContent = 'Please wait until the operation finishes.';

                if (submitter instanceof HTMLButtonElement) {
                    submitter.disabled = true;
                    submitter.classList.add('is-loading');
                    submitter.textContent = 'Working...';
                } else if (submitter instanceof HTMLInputElement) {
                    submitter.disabled = true;
                }

                const buttons = form.querySelectorAll('button, input[type="submit"]');
                for (const button of buttons) {
                    if (button !== submitter) {
                        button.disabled = true;
                    }
                }
            });
        }
    })();
</script>

@if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
{
    <div class="flash @(Model.FlashIsError ? "error" : "success")">@Model.FlashMessage</div>
}

<section class="grid stats">
    <article class="card">
        <div class="stat-value">@Model.PendingDraftCount</div>
        <div>Pending drafts</div>
        <div class="muted">@Model.ApprovedDraftCount approved and waiting for publication</div>
    </article>
    <article class="card">
        <div class="stat-value">@Model.ActiveSourceCount</div>
        <div>Active sources</div>
        <div class="muted">@Model.Sources.Count configured sources</div>
    </article>
    <article class="card">
        <div class="stat-value">@(Model.Runs.FirstOrDefault()?.ItemsCollected ?? 0)</div>
        <div>Latest collection</div>
        <div class="muted">Items from the latest recorded run</div>
    </article>
    <article class="card">
        <div class="stat-value">@(Model.LinkedInStatus.HasAccessToken ? "OK" : "Pending")</div>
        <div>LinkedIn</div>
        <div class="muted">@((Model.LinkedInStatus.MemberName ?? "Account not connected"))</div>
        @if (Model.LinkedInStatus.IsConfigured && !Model.LinkedInStatus.HasAccessToken)
        {
            <div class="muted" style="margin-top: 8px;">Reconnect LinkedIn to restore publishing access.</div>
        }
    </article>
</section>

<section class="card" style="margin-top: 20px;">
    <div class="toolbar">
        <div>
            <h2 style="margin-bottom: 6px;">Quick actions</h2>
            <div class="muted">Use the main button for news, image enrichment, and curation. Step-by-step actions stay available for troubleshooting.</div>
        </div>
        <div class="actions">
            <form method="post" action="/ops/linkedin/connect">
                @Html.AntiForgeryToken()
                <button type="submit" class="secondary">Connect LinkedIn</button>
            </form>
            <form method="post" action="/ops/linkedin/validate">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                <button type="submit" class="secondary">Validate LinkedIn</button>
            </form>
            <form method="post" action="/ops/linkedin/refresh">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                <button type="submit" class="secondary">Refresh token</button>
            </form>
        </div>
    </div>

    <div class="actions" style="margin-bottom: 12px;">
        <form method="post" action="/ops/actions/refresh-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <button type="submit" data-loading-text="Updating news, images, and drafts...">Update news + images + curation</button>
        </form>
    </div>

    <details>
        <summary style="cursor: pointer; font-weight: 600;">Advanced step-by-step actions</summary>
        <div class="actions" style="margin-top: 14px;">
        <form method="post" action="/ops/actions/daily">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <button type="submit" class="secondary">Run daily flow</button>
        </form>
        <form method="post" action="/ops/actions/collect">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <button type="submit" class="secondary">Run collection</button>
        </form>
        <form method="post" action="/ops/actions/curate">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <button type="submit" class="secondary">Run curation</button>
        </form>
        <form method="post" action="/ops/actions/normalize-news">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
            <button type="submit" class="secondary">Normalize news</button>
        </form>
        </div>
    </details>
</section>

<div class="grid main-grid" style="margin-top: 20px;">
    <div class="grid">
        <section class="card">
            <div class="toolbar">
                <div>
                    <h2 style="margin-bottom: 6px;">Drafts for review</h2>
                    <div class="muted">Sharper editorial structure, quality analysis, and a LinkedIn feed preview.</div>
                </div>
                <div class="preview-switch">
                    <a href="/ops?sort=@Model.NewsSort&preview=editorial&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.PreviewMode == "editorial" ? string.Empty : "secondary")">Editorial preview</a>
                    <a href="/ops?sort=@Model.NewsSort&preview=feed&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.PreviewMode == "feed" ? string.Empty : "secondary")">LinkedIn feed preview</a>
                </div>
            </div>

            <div class="preview-switch" style="margin-bottom: 16px; flex-wrap: wrap;">
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=review&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.DraftFilter == "review" ? string.Empty : "secondary")">Review (@Model.ReviewDraftCount)</a>
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=dismissed&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.DraftFilter == "dismissed" ? string.Empty : "secondary")">Dismissed (@Model.DismissedDraftCount)</a>
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=rejected&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.DraftFilter == "rejected" ? string.Empty : "secondary")">Rejected (@Model.RejectedDraftCount)</a>
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=failed&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.DraftFilter == "failed" ? string.Empty : "secondary")">Failed (@Model.FailedDraftCount)</a>
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=all&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.DraftFilter == "all" ? string.Empty : "secondary")">All (@Model.TotalEditableDraftCount)</a>
            </div>

            <div class="preview-switch" style="margin-bottom: 16px; flex-wrap: wrap;">
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=all&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=1&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.EditorialProfileFilter == "all" ? string.Empty : "secondary")">All profiles</a>
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=ai&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=1&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.EditorialProfileFilter == "ai" ? string.Empty : "secondary")">General AI</a>
                <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=dotnet&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=1&newsPage=1&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link @(Model.EditorialProfileFilter == "dotnet" ? string.Empty : "secondary")">.NET / C#</a>
            </div>

            <form method="get" action="/ops" style="display: flex; align-items: end; gap: 10px; margin-bottom: 16px;">
                <input type="hidden" name="sort" value="@Model.NewsSort" />
                <input type="hidden" name="preview" value="@Model.PreviewMode" />
                <input type="hidden" name="drafts" value="@Model.DraftFilter" />
                <input type="hidden" name="profile" value="@Model.EditorialProfileFilter" />
                <input type="hidden" name="newsQuery" value="@Model.NewsQuery" />
                <input type="hidden" name="sourceQuery" value="@Model.SourceQuery" />
                <input type="hidden" name="newsPage" value="@Model.NewsPage" />
                <input type="hidden" name="sourcePage" value="@Model.SourcePage" />
                <input type="hidden" name="runPage" value="@Model.RunPage" />
                <label style="margin: 0; flex: 1;">
                    Search drafts
                    <input type="search" name="draftQuery" value="@Model.DraftQuery" placeholder="title, text, tone..." />
                </label>
                <button type="submit" class="secondary">Search</button>
            </form>

            @if (Model.Drafts.Count == 0)
            {
                <p class="muted">
                    @(Model.DraftFilter switch
                    {
                        "dismissed" => "No dismissed drafts right now.",
                        "rejected" => "No rejected drafts right now.",
                        "failed" => "No failed drafts right now.",
                        "all" => "No editable drafts right now.",
                        _ => "No drafts waiting for review at the moment."
                    })
                </p>
            }
            else
            {
                <div class="list">
                    @foreach (var draftItem in Model.Drafts)
                    {
                        var draft = draftItem.Draft;
                        var editorial = draftItem.EditorialDraft;
                        var quality = draftItem.QualityAnalysis;
                        <article class="item">
                            <div class="item-header">
                                <div>
                                    <h3>@(string.IsNullOrWhiteSpace(draft.TitleSuggestion) ? $"Draft #{draft.Id}" : draft.TitleSuggestion)</h3>
                                    <div class="muted">
                                        Story #@draft.NewsItemId • prepared @draft.CreatedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                                        @if (!string.IsNullOrWhiteSpace(draftItem.SourceName))
                                        {
                                            <text> • source @draftItem.SourceName</text>
                                        }
                                    </div>
                                    <div class="meta-row">
                                        <span class="badge neutral">@draft.Tone tone</span>
                                        <span class="badge neutral">@draftItem.EditorialProfileLabel</span>
                                        @if (draftItem.LatestCuration is not null)
                                        {
                                            <span class="badge neutral">@draftItem.LatestCuration.Category</span>
                                        }
                                        <span class="badge neutral">readability @quality.ReadabilityScore</span>
                                        <span class="badge neutral">hook @((editorial.HookType ?? "selected").Replace("_", " "))</span>
                                        <span class="badge @(draftItem.IsReadyToPublish ? "success" : "warning")">@draftItem.ReadinessLabel</span>
                                        <span class="badge neutral">@draftItem.CharacterCount chars</span>
                                    </div>
                                </div>
                                <span class="badge">@draft.Status</span>
                            </div>

                            <div style="margin: 14px 0;">
                                <div class="muted" style="margin-bottom: 8px;">
                                    <strong>Visual asset:</strong>
                                    @(draftItem.HasPostImage ? " cover image available for future image-enabled LinkedIn publishing." : " text-first post with no supporting image captured.")
                                </div>

                                @if (draftItem.HasPostImage)
                                {
                                    <div class="muted" style="margin-bottom: 8px;">Image source: @(draftItem.PostImageOrigin ?? "Unknown")</div>
                                    <img src="@draftItem.PostImageUrl"
                                         alt="@(draftItem.NewsItem?.Title ?? draft.TitleSuggestion ?? $"Draft {draft.Id}")"
                                         style="width: 100%; max-height: 260px; object-fit: cover; border-radius: 14px; display: block;" />
                                }
                                else if (draftItem.NewsItem is not null)
                                {
                                    <details style="margin-top: 12px;">
                                        <summary style="cursor: pointer; font-weight: 600;">Add image manually</summary>
                                        <form method="post" action="/ops/news/@draftItem.NewsItem.Id/image" class="grid" style="margin-top: 12px;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                            <label>
                                                Image URL
                                                <input name="ImageForm.ImageUrl" value="@draftItem.ImageForm.ImageUrl" placeholder="https://example.com/image.jpg" />
                                            </label>
                                            <div class="actions">
                                                <button type="submit" class="secondary">Save image</button>
                                            </div>
                                        </form>
                                    </details>
                                }
                            </div>

                            @if (Model.PreviewMode == "feed")
                            {
                                <div class="feed-preview">
                                    <div class="feed-body"><strong>@editorial.Headline</strong>@editorial.Hook

@editorial.WhatHappened

@editorial.WhyItMatters

@editorial.StrategicTakeaway

Source: @editorial.SourceLabel
@if (!string.IsNullOrWhiteSpace(editorial.Hashtags))
{
<text>

@editorial.Hashtags</text>
}
@editorial.Signature</div>
                                </div>
                            }
                            else
                            {
                                <div class="editorial-preview">
                                    <div class="editorial-block">
                                        <h4>Headline</h4>
                                        <p class="editorial-headline">@editorial.Headline</p>
                                    </div>
                                    <div class="editorial-block">
                                        <h4>Opening angle</h4>
                                        <p class="editorial-hook">@editorial.Hook</p>
                                    </div>
                                    <div class="editorial-block">
                                        <h4>What happened</h4>
                                        <p>@editorial.WhatHappened</p>
                                    </div>
                                    <div class="editorial-block">
                                        <h4>Why it matters</h4>
                                        <p>@editorial.WhyItMatters</p>
                                    </div>
                                    <div class="editorial-block">
                                        <h4>Strategic takeaway</h4>
                                        <p>@editorial.StrategicTakeaway</p>
                                    </div>
                                    <div class="editorial-block">
                                        <h4>Source</h4>
                                        <p>@editorial.SourceLabel</p>
                                        @if (!string.IsNullOrWhiteSpace(editorial.Hashtags))
                                        {
                                            <p class="muted" style="margin-top: 8px;">@editorial.Hashtags</p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(editorial.Signature))
                                        {
                                            <p class="muted" style="margin-top: 8px;">@editorial.Signature</p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(draftItem.SourceUrl))
                                        {
                                            <div style="margin-top: 10px;">
                                                <a href="@draftItem.SourceUrl" target="_blank" rel="noreferrer" class="button-link secondary">Open original article</a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (quality.Warnings.Count > 0)
                            {
                                <div class="flash error">
                                    <strong>Quality warnings:</strong>
                                    <ul class="warning-list">
                                        @foreach (var warning in quality.Warnings)
                                        {
                                            <li>@warning</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (draftItem.ValidationErrors.Count > 0)
                            {
                                <div class="flash error">
                                    <strong>Editorial review notes:</strong>
                                    <div style="margin-top: 8px; white-space: pre-wrap;">@string.Join(Environment.NewLine, draftItem.ValidationErrors)</div>
                                </div>
                            }

                            @if (draftItem.HasFailedPublication)
                            {
                                <div class="flash error">
                                    <strong>Latest publication attempt failed.</strong>
                                    <div style="margin-top: 8px;">
                                        <span class="badge warning">@draftItem.LatestPublicationFailureCategory</span>
                                    </div>
                                    <div style="margin-top: 8px; white-space: pre-wrap;">@draftItem.LatestPublicationFailureSummary</div>
                                    <div class="muted" style="margin-top: 8px;">@draftItem.LatestPublicationFailureGuidance</div>
                                    @if (!string.IsNullOrWhiteSpace(draftItem.LatestPublicationTechnicalDetails))
                                    {
                                        <details style="margin-top: 10px;">
                                            <summary style="cursor: pointer; font-weight: 600;">Technical details</summary>
                                            <div style="margin-top: 8px; white-space: pre-wrap;">@draftItem.LatestPublicationTechnicalDetails</div>
                                        </details>
                                    }
                                </div>
                            }
                            else if (draftItem.LatestPublication?.Status == AiNewsCurator.Domain.Enums.PublicationStatus.Published)
                            {
                                <div class="flash success">
                                    <strong>Latest publication:</strong>
                                    <div style="margin-top: 8px;">
                                        @(draftItem.PublishedWithImage ? "Published with image." : "Published as text-only.")
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(draftItem.LatestPublication?.PlatformPostId))
                                    {
                                        <div class="muted" style="margin-top: 8px;">LinkedIn post id: @draftItem.LatestPublication.PlatformPostId</div>
                                    }
                                </div>
                            }

                            @if (draftItem.HasPublicationAudit)
                            {
                                <div class="flash" style="margin-top: 14px;">
                                    <strong>Publication audit</strong>
                                    @if (!string.IsNullOrWhiteSpace(draftItem.LatestPublicationSentText))
                                    {
                                        <div style="margin-top: 10px;">
                                            <div class="muted" style="margin-bottom: 6px;">Sent post text</div>
                                            <div style="white-space: pre-wrap;">@draftItem.LatestPublicationSentText</div>
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(draftItem.LatestPublicationRequestPayload))
                                    {
                                        <details style="margin-top: 10px;">
                                            <summary style="cursor: pointer; font-weight: 600;">Request payload</summary>
                                            <div style="margin-top: 8px; white-space: pre-wrap;">@draftItem.LatestPublicationRequestPayload</div>
                                        </details>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(draftItem.LatestPublicationResponsePayload))
                                    {
                                        <details style="margin-top: 10px;">
                                            <summary style="cursor: pointer; font-weight: 600;">Response payload</summary>
                                            <div style="margin-top: 8px; white-space: pre-wrap;">@draftItem.LatestPublicationResponsePayload</div>
                                        </details>
                                    }
                                </div>
                            }

                            @if (draftItem.HasPublicationHistory)
                            {
                                <details style="margin-top: 14px;">
                                    <summary style="cursor: pointer; font-weight: 600;">Publication attempts (@draftItem.PublicationHistory.Count)</summary>
                                    <div class="list" style="margin-top: 12px;">
                                        @foreach (var attempt in draftItem.PublicationHistory)
                                        {
                                            <article class="item" style="padding: 14px;">
                                                <div class="item-header">
                                                    <div>
                                                        <strong>@attempt.Status</strong>
                                                        <div class="muted" style="margin-top: 4px;">
                                                            Attempt #@attempt.Id
                                                            @if (attempt.PublishedAt.HasValue)
                                                            {
                                                                <text> • @attempt.PublishedAt.Value.LocalDateTime.ToString("dd/MM/yyyy HH:mm")</text>
                                                            }
                                                        </div>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(attempt.PlatformPostId))
                                                    {
                                                        <span class="badge">@attempt.PlatformPostId</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(attempt.ErrorMessage))
                                                {
                                                    <div class="muted" style="margin-top: 8px; white-space: pre-wrap;">@attempt.ErrorMessage</div>
                                                }
                                            </article>
                                        }
                                    </div>
                                </details>
                            }

                            <div class="inline-actions">
                                @if (draft.Status == AiNewsCurator.Domain.Enums.DraftStatus.PendingApproval)
                                {
                                    <form method="post" action="/ops/drafts/@draft.Id/approve">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit">Approve</button>
                                    </form>
                                    <form method="post" action="/ops/drafts/@draft.Id/dismiss">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit" class="secondary">Dismiss</button>
                                    </form>
                                    <form method="post" action="/ops/drafts/@draft.Id/reject">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit" class="danger">Reject</button>
                                    </form>
                                }

                                @if (draft.Status == AiNewsCurator.Domain.Enums.DraftStatus.Approved)
                                {
                                    <form method="post" action="/ops/drafts/@draft.Id/publish">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit">Publish to LinkedIn</button>
                                    </form>
                                    <form method="post" action="/ops/drafts/@draft.Id/dismiss">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit" class="secondary">Dismiss</button>
                                    </form>
                                }

                                @if (draft.Status == AiNewsCurator.Domain.Enums.DraftStatus.Dismissed ||
                                     draft.Status == AiNewsCurator.Domain.Enums.DraftStatus.Rejected ||
                                     draft.Status == AiNewsCurator.Domain.Enums.DraftStatus.Failed)
                                {
                                    <form method="post" action="/ops/drafts/@draft.Id/reopen">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit">Reopen for review</button>
                                    </form>
                                }

                                @if (draftItem.CanRetryPublish)
                                {
                                    <form method="post" action="/ops/drafts/@draft.Id/publish">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit">Retry publish</button>
                                    </form>
                                }

                                @if (draft.Status != AiNewsCurator.Domain.Enums.DraftStatus.Published)
                                {
                                    <form method="post" action="/ops/drafts/@draft.Id/regenerate">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit" class="secondary">Regenerate draft</button>
                                    </form>
                                    <form method="post" action="/ops/drafts/@draft.Id/replace">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                        <button type="submit" class="danger" data-loading-text="Removing and recreating draft...">Remove and recreate</button>
                                    </form>
                                }
                            </div>

                            <details style="margin-top: 18px;">
                                <summary style="cursor: pointer; font-weight: 600;">Edit draft</summary>
                                <form method="post" action="/ops/drafts/@draft.Id/edit" class="grid" style="margin-top: 14px;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                                    <label>
                                        Title suggestion
                                        <input name="EditForm.TitleSuggestion" value="@draftItem.EditForm.TitleSuggestion" />
                                    </label>

                                    <label>
                                        Post text
                                        <textarea name="EditForm.PostText" rows="12">@draftItem.EditForm.PostText</textarea>
                                    </label>

                                    <div class="actions">
                                        <button type="submit" class="secondary">Save draft changes</button>
                                    </div>
                                </form>
                            </details>
                        </article>
                    }
                </div>

                @if (Model.DraftTotalPages > 1)
                {
                    <div class="inline-actions" style="margin-top: 16px;">
                        @if (Model.DraftPage > 1)
                        {
                            <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@(Model.DraftPage - 1)&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link secondary">Previous drafts</a>
                        }
                        <span class="muted">Draft page @Model.DraftPage of @Model.DraftTotalPages</span>
                        @if (Model.DraftPage < Model.DraftTotalPages)
                        {
                            <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@(Model.DraftPage + 1)&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link secondary">Next drafts</a>
                        }
                    </div>
                }
            }
        </section>

        <section class="card">
            <div class="toolbar">
                <div>
                    <h2 style="margin-bottom: 6px;">Recent news</h2>
                    <div class="muted">Quick view of what was collected and why it was accepted or rejected.</div>
                </div>
                <form method="get" action="/ops" style="display: flex; align-items: end; gap: 10px;">
                    <input type="hidden" name="preview" value="@Model.PreviewMode" />
                    <input type="hidden" name="drafts" value="@Model.DraftFilter" />
                    <input type="hidden" name="profile" value="@Model.EditorialProfileFilter" />
                    <input type="hidden" name="draftQuery" value="@Model.DraftQuery" />
                    <input type="hidden" name="newsQuery" value="@Model.NewsQuery" />
                    <input type="hidden" name="sourceQuery" value="@Model.SourceQuery" />
                    <input type="hidden" name="draftPage" value="@Model.DraftPage" />
                    <input type="hidden" name="sourcePage" value="@Model.SourcePage" />
                    <input type="hidden" name="runPage" value="@Model.RunPage" />
                    <label style="margin: 0;">
                        Sort by
                        <select name="sort" onchange="this.form.submit()">
                            <option value="relevance" selected="@(Model.NewsSort == "relevance")">Relevance</option>
                            <option value="date" selected="@(Model.NewsSort == "date")">Date</option>
                            <option value="source" selected="@(Model.NewsSort == "source")">Source</option>
                        </select>
                    </label>
                </form>
            </div>

            <form method="get" action="/ops" style="display: flex; align-items: end; gap: 10px; margin-bottom: 16px;">
                <input type="hidden" name="sort" value="@Model.NewsSort" />
                <input type="hidden" name="preview" value="@Model.PreviewMode" />
                <input type="hidden" name="drafts" value="@Model.DraftFilter" />
                <input type="hidden" name="profile" value="@Model.EditorialProfileFilter" />
                <input type="hidden" name="draftQuery" value="@Model.DraftQuery" />
                <input type="hidden" name="sourceQuery" value="@Model.SourceQuery" />
                <input type="hidden" name="draftPage" value="@Model.DraftPage" />
                <input type="hidden" name="sourcePage" value="@Model.SourcePage" />
                <input type="hidden" name="runPage" value="@Model.RunPage" />
                <label style="margin: 0; flex: 1;">
                    Search news
                    <input type="search" name="newsQuery" value="@Model.NewsQuery" placeholder="title, summary, source..." />
                </label>
                <button type="submit" class="secondary">Search</button>
            </form>

            <div class="list">
                @foreach (var item in Model.NewsItems)
                {
                    <article class="item">
                        @if (!string.IsNullOrWhiteSpace(item.NewsItem.ImageUrl))
                        {
                            <div class="muted" style="margin-bottom: 8px;">Image source: @(item.NewsItem.ImageOrigin ?? "Unknown")</div>
                            <img src="@item.NewsItem.ImageUrl"
                                 alt="@item.NewsItem.Title"
                                 style="width: 100%; max-height: 240px; object-fit: cover; border-radius: 14px; margin-bottom: 14px;" />
                        }
                        else
                        {
                            <details style="margin-bottom: 14px;">
                                <summary style="cursor: pointer; font-weight: 600;">Add image manually</summary>
                                <form method="post" action="/ops/news/@item.NewsItem.Id/image" class="grid" style="margin-top: 12px;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                    <label>
                                        Image URL
                                        <input name="ImageForm.ImageUrl" value="@item.ImageForm.ImageUrl" placeholder="https://example.com/image.jpg" />
                                    </label>
                                    <div class="actions">
                                        <button type="submit" class="secondary">Save image</button>
                                    </div>
                                </form>
                            </details>
                        }

                        <div class="item-header">
                            <div>
                                <h3>@item.NewsItem.Title</h3>
                                <div class="muted">@item.NewsItem.PublishedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm") • status @item.NewsItem.Status • source @(item.SourceName ?? $"#{item.NewsItem.SourceId}")</div>
                            </div>
                            <a href="@item.NewsItem.CanonicalUrl" target="_blank" rel="noreferrer" class="button-link secondary">Open article</a>
                        </div>

                        @if (item.IsPublishedToLinkedIn)
                        {
                            <div class="flash success" style="margin-bottom: 14px;">
                                <strong>Published on LinkedIn:</strong>
                                <div style="margin-top: 8px;">
                                    @item.LinkedInPublishedAt?.LocalDateTime.ToString("dd/MM/yyyy HH:mm")
                                    @if (!string.IsNullOrWhiteSpace(item.LinkedInPostId))
                                    {
                                        <text> • post id @item.LinkedInPostId</text>
                                    }
                                </div>
                            </div>
                        }

                        @if (item.LatestCuration is not null)
                        {
                            <p><strong>Curation:</strong> @item.LatestCuration.WhyRelevant</p>
                            <p class="muted">Profile @item.EditorialProfileLabel • category @item.LatestCuration.Category</p>
                            <p class="muted">Relevance @item.LatestCuration.RelevanceScore.ToString("0.00") • confidence @item.LatestCuration.ConfidenceScore.ToString("0.00") • publish @(item.LatestCuration.ShouldPublish ? "yes" : "no")</p>
                        }
                        else
                        {
                            <p class="muted">No curation recorded yet.</p>
                        }

                        <div class="inline-actions">
                            <form method="post" action="/ops/news/@item.NewsItem.Id/draft">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                <button type="submit" class="secondary">Create manual draft</button>
                            </form>
                            <form method="post" action="/ops/news/@item.NewsItem.Id/reprocess">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                <button type="submit" class="secondary">Reprocess news</button>
                            </form>
                        </div>
                    </article>
                }
            </div>

            @if (Model.NewsTotalPages > 1)
            {
                <div class="inline-actions" style="margin-top: 16px;">
                    @if (Model.NewsPage > 1)
                    {
                        <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@Model.DraftPage&newsPage=@(Model.NewsPage - 1)&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link secondary">Previous news</a>
                    }
                    <span class="muted">News page @Model.NewsPage of @Model.NewsTotalPages</span>
                    @if (Model.NewsPage < Model.NewsTotalPages)
                    {
                        <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@Model.DraftPage&newsPage=@(Model.NewsPage + 1)&sourcePage=@Model.SourcePage&runPage=@Model.RunPage" class="button-link secondary">Next news</a>
                    }
                </div>
            }
        </section>
    </div>

    <div class="grid">
        <section class="card">
            <h2 style="margin-bottom: 6px;">LinkedIn</h2>
            <div class="list">
                <div class="item">
                    <div><strong>Configured:</strong> @(Model.LinkedInStatus.IsConfigured ? "yes" : "no")</div>
                    <div><strong>Token:</strong> @(Model.LinkedInStatus.HasAccessToken ? "available" : "missing")</div>
                    <div><strong>Member:</strong> @(Model.LinkedInStatus.MemberName ?? "-")</div>
                    <div><strong>Email:</strong> @(Model.LinkedInStatus.MemberEmail ?? "-")</div>
                    <div><strong>Updated:</strong> @(Model.LinkedInStatus.TokenUpdatedAt?.LocalDateTime.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                    @if (Model.LinkedInStatus.IsConfigured && !Model.LinkedInStatus.HasAccessToken)
                    {
                        <div class="flash error" style="margin-top: 12px; margin-bottom: 0;">LinkedIn authorization is missing or expired. Reconnect the account before publishing again.</div>
                    }
                    <div class="inline-actions" style="margin-top: 14px;">
                        <form method="post" action="/ops/linkedin/validate">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                            <button type="submit" class="secondary">Validate</button>
                        </form>
                        <form method="post" action="/ops/linkedin/refresh">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                            <button type="submit" class="secondary">Refresh token</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        <section class="card">
            <h2 style="margin-bottom: 6px;">New source</h2>
            <div class="muted" style="margin-bottom: 14px;">Quick setup for RSS and other simple sources.</div>

            <form method="post" action="/ops/sources" class="grid">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                <label>
                    Name
                    <input asp-for="CreateSource.Name" />
                </label>

                <div class="split">
                    <label>
                        Type
                        <select asp-for="CreateSource.Type">
                            <option value="Rss">RSS</option>
                            <option value="Site">Site</option>
                            <option value="Api">API</option>
                        </select>
                    </label>
                    <label>
                        Language
                        <input asp-for="CreateSource.Language" />
                    </label>
                </div>

                <label>
                    URL
                    <input asp-for="CreateSource.Url" />
                </label>

                <div class="split">
                    <label>
                        Editorial profile
                        <select asp-for="CreateSource.EditorialProfile">
                            <option value="ai">General AI</option>
                            <option value="dotnet">.NET / C#</option>
                            <option value="auto">Auto detect</option>
                        </select>
                    </label>
                    <label>
                        Priority
                        <input asp-for="CreateSource.Priority" type="number" />
                    </label>
                    <label>
                        Max items per run
                        <input asp-for="CreateSource.MaxItemsPerRun" type="number" min="1" />
                    </label>
                </div>

                <label>
                    Tags
                    <input asp-for="CreateSource.Tags" placeholder="ai, llm, agents" />
                </label>
                <label>
                    Include keywords
                    <input asp-for="CreateSource.IncludeKeywords" placeholder="openai, model, agent" />
                </label>
                <label>
                    Exclude keywords
                    <input asp-for="CreateSource.ExcludeKeywords" placeholder="sports, politics" />
                </label>

                <label style="display: flex; align-items: center; gap: 10px;">
                    <input asp-for="CreateSource.IsActive" type="checkbox" style="width: auto;" />
                    Activate immediately
                </label>

                <div class="actions">
                    <button type="submit">Save source</button>
                </div>
            </form>
        </section>

        <section class="card">
            <h2 style="margin-bottom: 6px;">Configured sources</h2>
            <div class="muted" style="margin-bottom: 14px;">The current editorial profile filter also applies to this source list.</div>
            <form method="get" action="/ops" style="display: flex; align-items: end; gap: 10px; margin-bottom: 16px;">
                <input type="hidden" name="sort" value="@Model.NewsSort" />
                <input type="hidden" name="preview" value="@Model.PreviewMode" />
                <input type="hidden" name="drafts" value="@Model.DraftFilter" />
                <input type="hidden" name="profile" value="@Model.EditorialProfileFilter" />
                <input type="hidden" name="draftQuery" value="@Model.DraftQuery" />
                <input type="hidden" name="newsQuery" value="@Model.NewsQuery" />
                <input type="hidden" name="draftPage" value="@Model.DraftPage" />
                <input type="hidden" name="newsPage" value="@Model.NewsPage" />
                <input type="hidden" name="runPage" value="@Model.RunPage" />
                <label style="margin: 0; flex: 1;">
                    Search sources
                    <input type="search" name="sourceQuery" value="@Model.SourceQuery" placeholder="name, URL, tags..." />
                </label>
                <button type="submit" class="secondary">Search</button>
            </form>
            <div class="list">
                @foreach (var source in Model.Sources)
                {
                    <article class="item">
                        <div class="item-header">
                            <div>
                                <h3>@source.Source.Name</h3>
                                <div class="muted">@source.Source.Type • priority @source.Source.Priority • max @source.Source.MaxItemsPerRun</div>
                                <div class="meta-row" style="margin-top: 8px;">
                                    <span class="badge neutral">@source.EditorialProfileLabel</span>
                                </div>
                            </div>
                            <span class="badge">@(source.Source.IsActive ? "Active" : "Inactive")</span>
                        </div>

                        <p><a href="@source.Source.Url" target="_blank" rel="noreferrer">@source.Source.Url</a></p>
                        <form method="post" action="/ops/sources/@source.Source.Id/toggle">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                            <button type="submit" class="secondary">@(source.Source.IsActive ? "Deactivate" : "Activate")</button>
                        </form>

                        <details style="margin-top: 18px;">
                            <summary style="cursor: pointer; font-weight: 600;">Edit source</summary>
                            <form method="post" action="/ops/sources/@source.Source.Id/edit" class="grid" style="margin-top: 14px;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                                <label>
                                    Name
                                    <input name="EditForm.Name" value="@source.EditForm.Name" />
                                </label>

                                <div class="split">
                                    <label>
                                        Editorial profile
                                        <select name="EditForm.EditorialProfile">
                                            <option value="ai" selected="@(source.EditForm.EditorialProfile == "ai")">General AI</option>
                                            <option value="dotnet" selected="@(source.EditForm.EditorialProfile == "dotnet")">.NET / C#</option>
                                            <option value="auto" selected="@(source.EditForm.EditorialProfile == "auto")">Auto detect</option>
                                        </select>
                                    </label>
                                    <label>
                                        Type
                                        <select name="EditForm.Type">
                                            <option value="Rss" selected="@(source.EditForm.Type == "Rss")">RSS</option>
                                            <option value="Site" selected="@(source.EditForm.Type == "Site")">Site</option>
                                            <option value="Api" selected="@(source.EditForm.Type == "Api")">API</option>
                                        </select>
                                    </label>
                                    <label>
                                        Language
                                        <input name="EditForm.Language" value="@source.EditForm.Language" />
                                    </label>
                                </div>

                                <label>
                                    URL
                                    <input name="EditForm.Url" value="@source.EditForm.Url" />
                                </label>

                                <div class="split">
                                    <label>
                                        Priority
                                        <input name="EditForm.Priority" type="number" value="@source.EditForm.Priority" />
                                    </label>
                                    <label>
                                        Max items per run
                                        <input name="EditForm.MaxItemsPerRun" type="number" min="1" value="@source.EditForm.MaxItemsPerRun" />
                                    </label>
                                </div>

                                <label>
                                    Tags
                                    <input name="EditForm.Tags" value="@source.EditForm.Tags" />
                                </label>
                                <label>
                                    Include keywords
                                    <input name="EditForm.IncludeKeywords" value="@source.EditForm.IncludeKeywords" />
                                </label>
                                <label>
                                    Exclude keywords
                                    <input name="EditForm.ExcludeKeywords" value="@source.EditForm.ExcludeKeywords" />
                                </label>

                                <label style="display: flex; align-items: center; gap: 10px;">
                                    <input name="EditForm.IsActive" type="checkbox" value="true" checked="@source.EditForm.IsActive" style="width: auto;" />
                                    Keep source active
                                </label>

                                <div class="actions">
                                    <button type="submit" class="secondary">Save source changes</button>
                                </div>
                            </form>
                        </details>
                    </article>
                }
            </div>

            @if (Model.SourceTotalPages > 1)
            {
                <div class="inline-actions" style="margin-top: 16px;">
                    @if (Model.SourcePage > 1)
                    {
                        <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@Model.DraftPage&newsPage=@Model.NewsPage&sourcePage=@(Model.SourcePage - 1)&runPage=@Model.RunPage" class="button-link secondary">Previous sources</a>
                    }
                    <span class="muted">Source page @Model.SourcePage of @Model.SourceTotalPages</span>
                    @if (Model.SourcePage < Model.SourceTotalPages)
                    {
                        <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@Model.DraftPage&newsPage=@Model.NewsPage&sourcePage=@(Model.SourcePage + 1)&runPage=@Model.RunPage" class="button-link secondary">Next sources</a>
                    }
                </div>
            }
        </section>

        <section class="card">
            <h2 style="margin-bottom: 6px;">Recent runs</h2>
            <div class="list">
                @foreach (var run in Model.Runs)
                {
                    <article class="item">
                        <div class="item-header">
                            <div>
                                <h3>Run #@run.Id</h3>
                                <div class="muted">@run.StartedAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm") • @run.TriggerType • @run.Status</div>
                            </div>
                            <span class="badge">published @run.ItemsPublished</span>
                        </div>
                        <p class="muted">Collected @run.ItemsCollected • curated @run.ItemsCurated • approved @run.ItemsApproved • errors @run.ErrorCount</p>
                    </article>
                }
            </div>

            @if (Model.RunTotalPages > 1)
            {
                <div class="inline-actions" style="margin-top: 16px;">
                    @if (Model.RunPage > 1)
                    {
                        <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@Model.DraftPage&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@(Model.RunPage - 1)" class="button-link secondary">Previous runs</a>
                    }
                    <span class="muted">Run page @Model.RunPage of @Model.RunTotalPages</span>
                    @if (Model.RunPage < Model.RunTotalPages)
                    {
                        <a href="/ops?sort=@Model.NewsSort&preview=@Model.PreviewMode&drafts=@Model.DraftFilter&profile=@Model.EditorialProfileFilter&draftQuery=@Model.DraftQuery&newsQuery=@Model.NewsQuery&sourceQuery=@Model.SourceQuery&draftPage=@Model.DraftPage&newsPage=@Model.NewsPage&sourcePage=@Model.SourcePage&runPage=@(Model.RunPage + 1)" class="button-link secondary">Next runs</a>
                    }
                </div>
            }
        </section>
    </div>
</div>
