@model AiNewsCurator.Api.Models.Operations.OperationsLoginViewModel
@{
    ViewData["Title"] = "Operations Login";
}

<style>
    .ops-login-loading {
        display: none;
        margin-top: 12px;
    }

    .ops-login-loading.active {
        display: block;
    }
</style>

<div style="min-height: 85vh; display: grid; place-items: center;">
    <div class="card" style="width: min(460px, 100%);">
        <div class="brand-lockup" style="margin-bottom: 12px;">
            <img src="~/favicon.png" alt="AI News Curator logo" class="brand-logo" />
            <div>
                <h1 style="margin-top: 0; margin-bottom: 0;">AI News Curator Ops</h1>
            </div>
        </div>
        <p class="muted">Enter your email to receive a one-time login code.</p>

        @if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
        {
            <div class="flash success">@Model.InfoMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="flash error">@Model.ErrorMessage</div>
        }

        @if (!string.Equals(Model.Step, "verify", StringComparison.OrdinalIgnoreCase))
        {
            <form method="post" action="/ops/auth/request-code">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <label asp-for="Email">
                    Email
                    <input asp-for="Email" type="email" autocomplete="email" />
                </label>

                <div class="actions" style="margin-top: 16px;">
                    <button type="submit">Send code</button>
                </div>
                <div id="ops-login-loading" class="ops-login-loading muted">Sending code... Please wait.</div>
            </form>
        }
        else
        {
            <p class="muted">Enter the 6-digit code sent to your email.</p>

            <form method="post" action="/ops/auth/verify-code">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                <label asp-for="Email">
                    Email
                    <input asp-for="Email" type="email" autocomplete="email" />
                </label>

                <label asp-for="Code">
                    6-digit code
                    <input asp-for="Code" inputmode="numeric" autocomplete="one-time-code" maxlength="6" pattern="[0-9]{6}" />
                </label>

                <div class="actions" style="margin-top: 16px;">
                    <button type="submit">Verify code</button>
                    <button type="submit" formaction="/ops/auth/request-code" class="secondary">Resend code</button>
                    <a class="button-link secondary" href="/ops/login?returnUrl=@Uri.EscapeDataString(Model.ReturnUrl)">Back</a>
                </div>
                <div id="ops-login-loading" class="ops-login-loading muted">Verifying code... Please wait.</div>
            </form>
        }
    </div>
</div>

<script>
    (() => {
        const form = document.querySelector('form[method="post"]');
        const loading = document.getElementById('ops-login-loading');
        if (!form || !loading) {
            return;
        }

        form.addEventListener('submit', event => {
            if (form.dataset.loadingActive === 'true') {
                event.preventDefault();
                return;
            }

            form.dataset.loadingActive = 'true';
            loading.classList.add('active');

            for (const button of form.querySelectorAll('button, input[type="submit"]')) {
                button.disabled = true;
            }
        });
    })();
</script>
